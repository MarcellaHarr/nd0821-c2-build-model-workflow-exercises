# Defining the Project Environment File

name: exercise_5_preprocess_data
conda_env: conda.yml

entry_points:
  main:
    parameters:
      input_artifact:
        description: Name of the input artifact to be used for preprocessing
        type: string
      artifact_name:
        description: Name of the output artifact to be created after preprocessing
        type: string
      artifact_type:
        description: Type of the output artifact to be created after preprocessing
        type: string
      artifact_description:
        description: Description of the output artifact to be created after preprocessing
        type: string

    command: >-
      python run.py --input_artifact {input_artifact} \
                --artifact_name {artifact_name} \
                --artifact_type {artifact_type} \
                --artifact_description {artifact_description}

# End of file
