# Defining the Project Environment File

name: download_data
conda_env: conda.yml

entry_points:
  main:
    parameters:
      file_url:
        description: The URL of the file to download
        type: uri

      artifact_name:
        description: The name of the artifact to create
        type: string

      artifact_type:
        description: The type of the artifact to create
        type: string
        default: raw_data

      artifact_description:
        description: The description of the artifact to create
        type: string

    command: >-
      python download_data.py --file_url {file_url} \
                              --artifact_name {artifact_name} \
                              --artifact_type {artifact_type} \
                              --artifact_description {artifact_description}

# End of file
